---
import { Icon } from "astro-icon/components";
---

	<fieldset class="mode-switcher-block">
		<div class="icon-block light">
			<input type="radio" name="switcher" id="light" value="light">
			<label class="icon-label light" for="light">
				Світла
				<Icon name="sun-filled" size={30} />
			</label>
		</div>
		<div class="icon-block dark">
			<input type="radio" name="switcher" id="dark" value="dark">
			<label class="icon-label dark" for="dark">
				<Icon name="moon-filled" size={30} />
				Темна
			</label>
		</div>
	</fieldset>

<style>
    .mode-switcher-block {
		display: flex;
		margin-bottom: 2rem;
	}

	fieldset {
		display: flex;
		gap: 1rem;
		margin-inline: 0;
		padding-block: 0;
		padding-inline: 0;
		border-width: 0;
	}

	label {
		line-height: 1;
		display: flex;
		align-items: center;
		gap: 1rem;
		transition: color 0.2s ease-in-out;
		
		&.light {
			padding-left: 0.5rem;
		}
		
		&.dark {
			padding-right: 0.5rem;
		}

		@media (min-width: 720px) {
			cursor: pointer;
		}
	}
	
	
	.icon-block {
		padding: 0.5rem;
		border: 1px solid rgb(92, 90, 90);
		border-radius: 100vw;
	}
	
	.icon-block:has(input[name="switcher"][type="radio"]:checked) {
		color: light-dark(var(--foreground), var(--foreground-dark));
		border: 1px solid light-dark(var(--footer), var(--foreground-dark));
		background: light-dark(oklch(85% 0.063 96.44), var(--active));
	}

	input[type="radio"] {
		display: none;
	}
</style>

<script is:inline>
    document.addEventListener('astro:page-load', () => {

        const radioButtons = document.querySelectorAll('input[name="switcher"]');

        // Set theme based on saved preference on load
        const currentTheme = sessionStorage.getItem('theme');
            if (currentTheme) {
            document.querySelector(`input[value="${currentTheme}"]`).checked = true;
        } 

        radioButtons.forEach(radio => {
            radio.addEventListener('change', (e) => {
                if (e.target.value === 'dark') {
                    sessionStorage.setItem('theme', 'dark');
                } else {
                    sessionStorage.setItem('theme', 'light');
                }
            });
        });
    });
</script>