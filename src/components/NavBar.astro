<style>

	button {
		height: 3.6rem;
        width: 100%;
		background-color: transparent;
		color: light-dark(oklch(85% 0.063 96.44), var(--foreground-dark));
		border: 0;
		z-index: 2;
	}

	.tooltip {
		margin: 0;
		padding: 0;
		width: 100%;
		position-area: top;
		background-color: var(--header);
		border: 0;
		overflow: visible;
		z-index: -1;

		@media (min-width: 720px) {
			position-area: right;
			width: fit-content;
			background-color: light-dark(var(--active-green), var(--footer));
			border-radius: 0 1rem 1rem 0;
	
			&::before, &::after {
				position: absolute;
				content: '';
				width: 18px;
				aspect-ratio: 1;
			}
	
			&::before {
				left: 0;
				top: -18px;
				background: radial-gradient(
					circle 18px at top right,
					#0000 98%, light-dark(var(--active-green), var(--footer))
				);
			}
	
			&::after {
				left: 0;
				bottom: -18px;
				background: radial-gradient(
					circle 18px at bottom right,
					#0000 98%, light-dark(var(--active-green), var(--footer))
				);
			}
		}

		a {
			color: var(--foreground-dark);
			text-decoration: none;
            line-height: 2.7rem;
		}

		a:hover {
			color: light-dark(var(--foreground), var(--active));
		}

		}

		ul {
			list-style: none;
			padding: 1rem 0;
		}

        li {
            padding: 0 1rem;
        }

        li:has(a.active) {
            background: var(--button);
            color: light-dark(var(--active), var(--background));
        }

	[popover] {
		translate: -360px 0;
		transition: translate 0.5s ease-out, display 0.5s ease-out allow-discrete;

		&:popover-open {
            translate: 1rem 0;
        }
	}

	@starting-style {
		[popover]:popover-open {
            translate: -360px 0;
        }
	}
</style>