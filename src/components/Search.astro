---

---
<section class="search-bar">
	<input type="search" class="search-input" placeholder="Пошук..." tabindex="0">
	<button class="search-submit" tabindex="0">
		<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 15 15"><path fill="currentColor" d="M6.5 2a4.5 4.5 0 0 1 3.515 7.308l2.839 2.839l.064.078a.5.5 0 0 1-.693.693l-.079-.064l-2.838-2.84A4.5 4.5 0 1 1 6.5 2m0 1a3.5 3.5 0 1 0 0 7a3.5 3.5 0 0 0 0-7"/></svg>
	</button>
</section>

<style>
    button {
		padding: 0;
		margin: 0;
	}
	.search-bar {
		--size: 3rem;
		--padding: 0.3rem;
		--expanded-width: 300px;

		display: flex;
		justify-content: flex-end;
		background-color: #fff;
		box-shadow: 0 10px 10px 0 #d6d9e2;
		border-radius: 100px;
		overflow: hidden;

		padding: var(--padding);
		margin-left: auto;
		width: var(--size);
		height: var(--size);
		max-width: 100%;
		outline: 1px solid transparent;
		transition: width 0.5s, outline 0.5s;
	}
	.search-bar:focus-within {
		width: var(--expanded-width);
		outline: 1px solid #2e2e2e;
	}
	.search-bar:focus-within .search-input {
	  	opacity: 1;
	}
	.search-input {
		font-size: 18px;
		flex: auto;
		color: #3a3a3a;
		background-color: transparent;
		margin-inline: 1rem;
		border: none;
		outline: none;
		
		opacity: 0;
		transition: opacity 0.5s;
	}
	.search-submit {
		flex: none;
		display: flex;
		justify-content: center;
		align-items: center;
		font-size: 18px;
		color: #fff;
		background-color: #3a3a3a;
		border-radius: 50%;
		border: none;
		width: var(--size);
		cursor: pointer;
		aspect-ratio: 1;
	}
</style>